@{
    ViewData["Title"] = "BuildForge";
}

<div class="page-header">
    <h1>BuildForge</h1>
    <p class="lead">
        Create custom PC builds, browse hardware components, and check compatibility before finalizing your setup.
    </p>
    <a asp-controller="PcComponents" asp-action="Index" class="btn btn-light">
        Browse Components
    </a>
    <a asp-controller="Builds" asp-action="Index" class="btn btn-outline-light">
        My Builds
    </a>
</div>

<div class="row g-4">
    <div class="col-md-4">
        <div class="card card-buildforge h-100">
            <div class="card-body">
                <h5 class="card-title">Browse Parts</h5>
                <p class="card-text">
                    Search and filter CPUs, GPUs, RAM, motherboards, cases, and power supplies.
                </p>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card card-buildforge h-100">
            <div class="card-body">
                <h5 class="card-title">Create Builds</h5>
                <p class="card-text">
                    Save custom PC configurations and keep track of selected components and total price.
                </p>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card card-buildforge h-100">
            <div class="card-body">
                <h5 class="card-title">Check Compatibility</h5>
                <p class="card-text">
                    Detect issues such as CPU and motherboard socket mismatches or weak power supplies.
                </p>
            </div>
        </div>
    </div>
</div>