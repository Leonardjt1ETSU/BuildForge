@model IEnumerable<BuildForgeApp.Models.PcComponent>

@{
    ViewData["Title"] = "Component Catalog";
    var categories = ViewBag.Categories as List<string> ?? new List<string>();
    var brands = ViewBag.Brands as List<string> ?? new List<string>();
    var selectedCategory = ViewBag.SelectedCategory as string;
    var searchString = ViewBag.SearchString as string;
    var selectedBrand = ViewBag.SelectedBrand as string;
}

<h1>Component Catalog</h1>

<form asp-action="Index" method="get" class="mb-4">
    <div class="row g-3">
        <div class="col-md-4">
            <label class="form-label">Search</label>
            <input type="text" name="searchString" value="@searchString" class="form-control" placeholder="Search components..." />
        </div>

        <div class="col-md-3">
            <label class="form-label">Category</label>
            <select name="category" class="form-select">
                <option value="">All Categories</option>
                @foreach (var category in categories)
                {
                    if (selectedCategory == category)
                    {
                        <option value="@category" selected>@category</option>
                    }
                    else
                    {
                        <option value="@category">@category</option>
                    }
                }
            </select>
        </div>

        <div class="col-md-3">
            <label class="form-label">Brand</label>
            <select name="brand" class="form-select">
                <option value="">All Brands</option>
                @foreach (var brand in brands)
                {
                    if (selectedBrand == brand)
                    {
                        <option value="@brand" selected>@brand</option>
                    }
                    else
                    {
                        <option value="@brand">@brand</option>
                    }
                }
            </select>
        </div>

        <div class="col-md-2 d-flex align-items-end">
            <button type="submit" class="btn btn-primary w-100">Apply</button>
        </div>
    </div>
</form>

<div class="mb-4">
    <h4>Browse by Category</h4>
    <div class="d-flex flex-wrap gap-2">
        <a asp-action="Index" class="btn btn-outline-secondary">All</a>
        @foreach (var category in categories)
        {
            <a asp-action="Index" asp-route-category="@category" class="btn btn-outline-primary">@category</a>
        }
    </div>
</div>

@if (!Model.Any())
{
    <p>No components matched your search or filters.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Name</th>
                <th>Brand</th>
                <th>Type</th>
                <th>Price</th>
                <th>Socket</th>
                <th>Form Factor</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.Brand</td>
                <td>@item.ComponentType</td>
                <td>@item.Price.ToString("C")</td>
                <td>@(string.IsNullOrEmpty(item.SocketType) ? "N/A" : item.SocketType)</td>
                <td>@(string.IsNullOrEmpty(item.FormFactor) ? "N/A" : item.FormFactor)</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Details</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
}