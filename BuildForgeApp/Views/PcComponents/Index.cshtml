@model IEnumerable<BuildForgeApp.Models.PcComponent>

@{
    ViewData["Title"] = "Component Catalog";
    var categories = ViewBag.Categories as List<string> ?? new List<string>();
    var brands = ViewBag.Brands as List<string> ?? new List<string>();
    var selectedCategory = ViewBag.SelectedCategory as string;
    var selectedBrand = ViewBag.SelectedBrand as string;
}

<h1>Component Catalog</h1>

<form asp-action="Index" method="get" class="mb-4">
    <input type="hidden" name="buildId" value="@ViewBag.BuildId" />

    <div class="row g-3">
        <div class="col-md-4">
            <input type="text" name="searchString" class="form-control" placeholder="Search..." />
        </div>

        <div class="col-md-3">
            <select name="category" class="form-select">
                <option value="">All Categories</option>
                @foreach (var c in categories)
                {
                    <option value="@c">@c</option>
                }
            </select>
        </div>

        <div class="col-md-3">
            <select name="brand" class="form-select">
                <option value="">All Brands</option>
                @foreach (var b in brands)
                {
                    <option value="@b">@b</option>
                }
            </select>
        </div>

        <div class="col-md-2">
            <button class="btn btn-primary w-100">Filter</button>
        </div>
    </div>
</form>

<table class="table">
    <thead>
        <tr>
            <th>Name</th>
            <th>Brand</th>
            <th>Type</th>
            <th>Price</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model)
{
        <tr>
            <td>@item.Name</td>
            <td>@item.Brand</td>
            <td>@item.ComponentType</td>
            <td>@item.Price.ToString("C")</td>
            <td>
                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Details</a>

                @if (ViewBag.BuildId != null)
                {
                    <form asp-action="AddToBuild" method="post" style="display:inline;">
                        <input type="hidden" name="buildId" value="@ViewBag.BuildId" />
                        <input type="hidden" name="componentId" value="@item.Id" />
                        <button type="submit" class="btn btn-sm btn-success">Add</button>
                    </form>
                }
            </td>
        </tr>
}
    </tbody>
</table>
