@model BuildForgeApp.Models.Build

@{
    ViewData["Title"] = "Delete Build";
}

<h1>Delete Build</h1>

<div asp-validation-summary="All" class="text-danger"></div>

<h4>Are you sure you want to delete this build?</h4>

<hr />

<dl class="row">
    <dt class="col-sm-3">Build Name</dt>
    <dd class="col-sm-9">@Model.BuildName</dd>

    <dt class="col-sm-3">Created Date</dt>
    <dd class="col-sm-9">@Model.CreatedDate.ToString("g")</dd>

    <dt class="col-sm-3">Total Price</dt>
    <dd class="col-sm-9">@Model.TotalPrice.ToString("C")</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />

    <button type="submit" class="btn btn-danger">
        Delete
    </button>

    <a asp-action="Index" class="btn btn-secondary">
        Cancel
    </a>
</form>