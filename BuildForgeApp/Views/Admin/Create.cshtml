@model BuildForgeApp.Models.PcComponent

@{
    ViewData["Title"] = "Add Component";
}

<h1>Add Component</h1>

<form asp-action="Create" method="post">
    <div asp-validation-summary="All" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Brand" class="form-label"></label>
        <input asp-for="Brand" class="form-control" />
        <span asp-validation-for="Brand" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="ComponentType" class="form-label"></label>
        <select asp-for="ComponentType" class="form-select">
            <option value="">Select Type</option>
            <option value="CPU">CPU</option>
            <option value="Motherboard">Motherboard</option>
            <option value="GPU">GPU</option>
            <option value="RAM">RAM</option>
            <option value="PSU">PSU</option>
            <option value="Case">Case</option>
            <option value="Storage">Storage</option>
        </select>
        <span asp-validation-for="ComponentType" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Price" class="form-label"></label>
        <input asp-for="Price" class="form-control" />
        <span asp-validation-for="Price" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="SocketType" class="form-label"></label>
        <input asp-for="SocketType" class="form-control" placeholder="AM4, AM5, LGA1700, etc." />
        <span asp-validation-for="SocketType" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="FormFactor" class="form-label"></label>
        <input asp-for="FormFactor" class="form-control" placeholder="ATX, Micro-ATX, etc." />
        <span asp-validation-for="FormFactor" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Wattage" class="form-label"></label>
        <input asp-for="Wattage" class="form-control" />
        <span asp-validation-for="Wattage" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="CapacityGB" class="form-label"></label>
        <input asp-for="CapacityGB" class="form-control" />
        <span asp-validation-for="CapacityGB" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="StockQuantity" class="form-label"></label>
        <input asp-for="StockQuantity" class="form-control" />
        <span asp-validation-for="StockQuantity" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Add Component</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}