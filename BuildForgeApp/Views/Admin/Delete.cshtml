@model BuildForgeApp.Models.PcComponent

@{
    ViewData["Title"] = "Deactivate Component";
}

<h1>Deactivate Component</h1>

<div asp-validation-summary="All" class="text-danger"></div>

<p>Are you sure you want to deactivate this component?</p>

<dl class="row">
    <dt class="col-sm-3">Name</dt>
    <dd class="col-sm-9">@Model.Name</dd>

    <dt class="col-sm-3">Brand</dt>
    <dd class="col-sm-9">@Model.Brand</dd>

    <dt class="col-sm-3">Type</dt>
    <dd class="col-sm-9">@Model.ComponentType</dd>

    <dt class="col-sm-3">Price</dt>
    <dd class="col-sm-9">@Model.Price.ToString("C")</dd>
</dl>

<form asp-action="Delete" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />

    <button type="submit" class="btn btn-danger">Deactivate</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>